		"react-dom": "catalog:",
		"tailwind-merge": "catalog:"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "catalog:",
		"@types/mdx": "catalog:",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "catalog:",
