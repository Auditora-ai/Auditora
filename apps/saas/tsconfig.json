{
	"extends": "@repo/tsconfig/nextjs.json",
	"compilerOptions": {
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./*"],
			"@config": ["./config"],
			"@organizations/*": ["./modules/organizations/*"],
			"@auth/*": ["./modules/auth/*"],
			"@settings/*": ["./modules/settings/*"],
			"@payments/*": ["./modules/payments/*"],
			"@i18n/*": ["./modules/i18n/*"],
			"@admin/*": ["./modules/admin/*"],
			"@ai/*": ["./modules/ai/*"],
			"@onboarding/*": ["./modules/onboarding/*"],
			"@shared/*": ["./modules/shared/*"],
			"@meeting/*": ["./modules/meeting/*"],
			"@sessions/*": ["./modules/sessions/*"],
			"@clients/*": ["./modules/clients/*"],
			"@projects/*": ["./modules/projects/*"],
			"@documents/*": ["./modules/documents/*"],
			"@dashboard/*": ["./modules/dashboard/*"],
			"@command-center/*": ["./modules/command-center/*"],
			"@process-library/*": ["./modules/process-library/*"],
			"@discovery/*": ["./modules/discovery/*"],
			"@deliverables/*": ["./modules/deliverables/*"],
			"@ai-interview/*": ["./modules/ai-interview/*"],
			"@evaluaciones/*": ["./modules/evaluaciones/*"],
			"@scan/*": ["./modules/scan/*"],
			"@notifications/*": ["./modules/notifications/*"],
			"@change-management/*": ["./modules/change-management/*"],
			"@collaboration/*": ["./modules/collaboration/*"],
			"@home/*": ["./modules/home/*"],
			"@process/*": ["./modules/process/*"],
			"@capture/*": ["./modules/capture/*"],
			"@evaluate/*": ["./modules/evaluate/*"],
			"@panorama/*": ["./modules/panorama/*"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"**/*.cjs",
		"**/*.mjs",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
