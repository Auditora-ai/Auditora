datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "./zod"
  config   = "./zod-generator.config.json"
}

model User {
  id                       String       @id @default(cuid())
  name                     String
  email                    String
  emailVerified            Boolean
  image                    String?
  createdAt                DateTime
  updatedAt                DateTime
  username                 String?
  role                     String?
  banned                   Boolean?
  banReason                String?
  banExpires               DateTime?
  onboardingComplete       Boolean      @default(false)
  paymentsCustomerId       String?
  locale                   String?
  displayUsername          String?
  twoFactorEnabled         Boolean?
  lastActiveOrganizationId String?
  sessions                 Session[]
  accounts                 Account[]
  passkeys                 Passkey[]
  invitations              Invitation[]
  purchases                Purchase[]
  members                  Member[]
  twofactors               TwoFactor[]
  meetingSessions          MeetingSession[]
  simulationRuns           SimulationRun[]
  humanRiskProfiles        HumanRiskProfile[]
  notificationsReceived    Notification[]      @relation("NotificationRecipient")
  notificationsActed       Notification[]      @relation("NotificationActor")
  changeInitiated          ChangeConfirmation[] @relation("ChangeInitiator")
  changeResponses          ChangeConfirmationResponse[]
  notificationPreferences  NotificationPreference[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  activeOrganizationId String?

  token     String
  createdAt DateTime
  updatedAt DateTime

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  idToken      String?   @db.Text
  expiresAt    DateTime?
  password     String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime

  createdAt DateTime?
  updatedAt DateTime?

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Organization {
  id                 String       @id @default(cuid())
  name               String
  slug               String?
  logo               String?
  createdAt          DateTime
  metadata           String?
  paymentsCustomerId String?
  // Client profile fields (migrated from Client model)
  industry           String?
  operationsProfile  String?      @db.Text
  businessModel      String?      @db.Text
  employeeCount      String?
  notes              String?      @db.Text
  // AI tier configuration
  aiTier             String?      @default("standard") // "budget" | "standard" | "premium"
  aiTokenBudget      Int?         // monthly soft limit (null = unlimited)
  // Session credit system
  sessionCreditsUsed  Int          @default(0)  // credits consumed this billing cycle
  sessionCreditsLimit Int?         // credits per cycle from plan (null = unlimited)
  billingCycleAnchor  DateTime?    // day-of-month anchor for credit reset
  // BYOK: encrypted API keys (AES-256-GCM)
  aiAnthropicKey     String?      @db.Text
  aiDeepseekKey      String?      @db.Text
  aiKeysUpdatedAt    DateTime?
  members            Member[]
  invitations        Invitation[]
  purchases          Purchase[]
  sessions           MeetingSession[]
  architecture       ProcessArchitecture?
  documents          Document[]
  discoveryThreads   DiscoveryThread[]
  companyBrain       CompanyBrain?
  orgDeliverables    OrgDeliverable[]
  aiUsageLogs        AiUsageLog[]
  externalCostLogs   ExternalCostLog[]
  simulationTemplates SimulationTemplate[]
  humanRiskProfiles   HumanRiskProfile[]
  procedures          Procedure[]
  notifications           Notification[]
  changeConfirmations     ChangeConfirmation[]
  notificationPreferences NotificationPreference[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ============================================
// AIPROCESS MODELS
// ============================================

enum SessionType {
  DISCOVERY
  DEEP_DIVE
  CONTINUATION
  AI_INTERVIEW
}

enum ProcessLevel {
  MACRO_PROCESS
  PROCESS
  SUBPROCESS
  TASK
  PROCEDURE
}

enum SessionStatus {
  SCHEDULED
  CONNECTING
  ACTIVE
  ENDED
  FAILED
  CANCELLED
}

enum NodeState {
  FORMING
  CONFIRMED
  REJECTED
  ARCHIVED
}

enum NodeType {
  START_EVENT
  END_EVENT
  TASK
  USER_TASK
  SERVICE_TASK
  MANUAL_TASK
  BUSINESS_RULE_TASK
  SUBPROCESS
  EXCLUSIVE_GATEWAY
  PARALLEL_GATEWAY
  TIMER_EVENT
  MESSAGE_EVENT
  SIGNAL_EVENT
  CONDITIONAL_EVENT
  TEXT_ANNOTATION
  DATA_OBJECT
}

enum IntelligenceItemStatus {
  OPEN
  RESOLVED
  SUPERSEDED
}

enum IntelligenceItemCategory {
  MISSING_PATH
  MISSING_ROLE
  MISSING_EXCEPTION
  MISSING_DECISION
  MISSING_TRIGGER
  MISSING_OUTPUT
  CONTRADICTION
  UNCLEAR_HANDOFF
  MISSING_SLA
  MISSING_SYSTEM
  GENERAL_GAP
}

// ============================================
// RISK ENUMS
// ============================================

enum RiskType {
  OPERATIONAL
  COMPLIANCE
  STRATEGIC
  FINANCIAL
  TECHNOLOGY
  HUMAN_RESOURCE
  REPUTATIONAL
}

enum RiskStatus {
  IDENTIFIED
  ASSESSED
  MITIGATING
  ACCEPTED
  CLOSED
}

enum RiskSource {
  AI_AUDIT
  AI_FMEA
  INTELLIGENCE_GAP
  MANUAL
  CONVERSATION
}

enum MitigationStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ControlType {
  PREVENTIVE
  DETECTIVE
  CORRECTIVE
}

enum ControlEffectiveness {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

model ProcessArchitecture {
  id             String                @id @default(cuid())
  organizationId String                @unique
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  definitions    ProcessDefinition[]
  versions       ArchitectureVersion[]

  // Project plan for Gantt chart (general tasks, process schedule, scope)
  projectPlan    Json?

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@map("process_architecture")
}

model ProcessDefinition {
  id             String              @id @default(cuid())
  architectureId String
  architecture   ProcessArchitecture @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  name           String
  description    String?             @db.Text
  level          ProcessLevel        @default(PROCESS)
  parentId       String?
  parent         ProcessDefinition?  @relation("ProcessHierarchy", fields: [parentId], references: [id])
  children       ProcessDefinition[] @relation("ProcessHierarchy")
  owner          String?
  goals          String[]
  triggers       String[]
  outputs        String[]
  processStatus  String              @default("DRAFT")
  category       String?             // 'strategic' | 'core' | 'support'
  bpmnXml        String?             @db.Text
  priority       Int                 @default(0)
  sessions       MeetingSession[]
  versions       ProcessVersion[]
  raciEntries    RaciEntry[]
  conflicts      StakeholderConflict[]
  intelligence   ProcessIntelligence?
  risks            ProcessRisk[]
  documents        Document[]
  discoveryThreads DiscoveryThread[]
  simulationTemplates SimulationTemplate[]
  procedures          Procedure[]
  changeConfirmations ChangeConfirmation[]
  createdAt        DateTime            @default(now())

  @@index([architectureId])
  @@index([parentId])
  @@map("process_definition")
}

model MeetingSession {
  id                  String            @id @default(cuid())
  type                SessionType
  status              SessionStatus     @default(SCHEDULED)
  meetingUrl          String?
  organizationId      String
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processDefinitionId String?
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id])
  userId              String
  user                User              @relation(fields: [userId], references: [id])

  // Session continuation
  continuationOf      String?
  previousSession     MeetingSession?   @relation("SessionContinuation", fields: [continuationOf], references: [id])
  nextSessions        MeetingSession[]  @relation("SessionContinuation")

  // Call bot
  recallBotId         String?
  recallBotStatus     String?

  // Scheduling
  scheduledFor        DateTime?
  scheduledEnd        DateTime?
  sessionGoals        String?           @db.Text
  sessionContext      String?           @db.Text  // AI-synthesized preparation brief from wizard

  // Client intake
  intakeToken         String?           @unique @default(cuid())
  intakeStatus        String?           @default("pending") // pending | partial | complete
  intakeResponses     ClientIntakeResponse[]

  // Participants
  participants        MeetingParticipant[]

  // Timing
  startedAt           DateTime?
  endedAt             DateTime?

  // Teleprompter mode (explore | deepen | validate)
  questionMode        String            @default("explore")

  // AI Interview data
  conversationLog     Json?             // Array<{role, content, timestamp, metadata}>
  knowledgeSnapshot   Json?             // Accumulated KnowledgeSnapshot from AI interview

  // BPMN data
  bpmnXml             String?           @db.Text
  diagramNodes        DiagramNode[]
  transcriptEntries   TranscriptEntry[]
  correctionLogs      CorrectionLog[]
  teleprompterLogs    TeleprompterLog[]
  sessionSummary      SessionSummary?
  sessionDeliverables SessionDeliverable[]

  // Recall.ai media
  videoUrl            String?
  audioUrl            String?

  // Share
  shareToken          String?           @unique @default(cuid())

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([shareToken])
  @@index([intakeToken])
  @@index([scheduledFor])
  @@map("meeting_session")
}

model DiagramNode {
  id        String         @id @default(cuid())
  sessionId String
  session   MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nodeType  NodeType
  label     String
  state     NodeState      @default(FORMING)
  lane      String?
  confidence Float?
  positionX Float          @default(0)
  positionY Float          @default(0)

  // Connections stored as JSON array of target node IDs
  connections      String[]
  connectionLabels String[]

  // Timing
  formedAt    DateTime     @default(now())
  confirmedAt DateTime?
  rejectedAt  DateTime?

  // Parent reference for cascade rejection
  parentId    String?

  // Task properties (description, SLA, systems, inputs/outputs, costs, etc.)
  properties  Json?

  // Generated SOP/procedure document (ProcedureResult JSON)
  procedure   Json?

  comments    NodeComment[]
  risks       ProcessRisk[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sessionId])
  @@index([state])
  @@map("diagram_node")
}

model NodeComment {
  id            String      @id @default(cuid())
  nodeId        String
  node          DiagramNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  content       String      @db.Text
  authorId      String
  authorName    String
  sourceType    String?     // 'manual' | 'transcript' | 'ai'
  sourceSnippet String?     @db.Text // original transcript text if sourceType='transcript'
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([nodeId])
  @@map("node_comment")
}

model TranscriptEntry {
  id            String         @id @default(cuid())
  sessionId     String
  session       MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker       String
  text          String         @db.Text
  correctedText String?        @db.Text
  timestamp     Float
  confidence    Float?
  source        String         @default("deepgram") // "deepgram" | "manual"

  createdAt DateTime       @default(now())

  @@index([sessionId])
  @@index([timestamp])
  @@map("transcript_entry")
}

model CorrectionLog {
  id        String         @id @default(cuid())
  sessionId String
  session   MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nodeId    String
  action    String         // "confirm", "reject", "edit", "undo"
  oldState  String?
  newState  String?
  oldLabel  String?
  newLabel  String?
  createdAt DateTime       @default(now())

  @@index([sessionId])
  @@map("correction_log")
}

model TeleprompterLog {
  id                String         @id @default(cuid())
  sessionId         String
  session           MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question          String         @db.Text
  used              Boolean        @default(false)
  skipped           Boolean        @default(false)
  shownAt           DateTime       @default(now())
  completenessScore Int?
  gapType           String?
  sipocCoverage     Json?

  @@index([sessionId])
  @@map("teleprompter_log")
}

model SessionSummary {
  id          String         @id @default(cuid())
  sessionId   String         @unique
  session     MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  summary     String         @db.Text
  actionItems String[]
  emailSentAt DateTime?

  createdAt   DateTime       @default(now())

  @@map("session_summary")
}

model SessionDeliverable {
  id          String         @id @default(cuid())
  sessionId   String
  session     MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        String         // "summary" | "process_audit" | "raci" | "risk_audit"
  status      String         @default("pending") // "pending" | "running" | "completed" | "failed" | "skipped"
  data        Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([sessionId, type])
  @@index([sessionId])
  @@index([status])
  @@map("session_deliverable")
}

model MeetingParticipant {
  id              String         @id @default(cuid())
  sessionId       String
  session         MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  role            String?
  participantType String?        // CLIENT | CONSULTANT | OBSERVER
  talkTimeMs      Int            @default(0)
  joinedAt        DateTime?
  leftAt          DateTime?

  createdAt       DateTime       @default(now())

  @@index([sessionId])
  @@map("meeting_participant")
}

// ============================================
// DISCOVERY CHAT MODELS
// ============================================

model DiscoveryThread {
  id                    String              @id @default(cuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processDefinitionId   String?
  processDefinition     ProcessDefinition?  @relation(fields: [processDefinitionId], references: [id], onDelete: SetNull)
  createdBy             String
  rejectedProcessNames  String[]            @default([])
  messages              DiscoveryMessage[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([organizationId])
  @@index([organizationId, processDefinitionId])
  @@map("discovery_thread")
}

model DiscoveryMessage {
  id                 String          @id @default(cuid())
  threadId           String
  thread             DiscoveryThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role               String          // 'user' | 'assistant'
  content            String          @db.Text
  audioFileUrl       String?
  extractedProcesses Json?           // snapshot of processes extracted in this message
  createdAt          DateTime        @default(now())

  @@index([threadId])
  @@map("discovery_message")
}

// ============================================
// RACI & COLLABORATION MODELS
// ============================================

enum RaciType {
  RESPONSIBLE
  ACCOUNTABLE
  CONSULTED
  INFORMED
}

model RaciEntry {
  id           String            @id @default(cuid())
  processId    String
  process      ProcessDefinition @relation(fields: [processId], references: [id], onDelete: Cascade)
  activityName String
  role         String
  assignment   RaciType
  source       String?
  createdAt    DateTime          @default(now())

  @@index([processId])
  @@map("raci_entry")
}

model StakeholderConflict {
  id           String            @id @default(cuid())
  processId    String
  process      ProcessDefinition @relation(fields: [processId], references: [id], onDelete: Cascade)
  nodeLabel    String
  conflictType String
  perspectives Json
  resolved     Boolean           @default(false)
  resolution   String?           @db.Text
  createdAt    DateTime          @default(now())

  @@index([processId])
  @@map("stakeholder_conflict")
}

// ============================================
// PROCESS INTELLIGENCE MODELS
// ============================================

model ProcessIntelligence {
  id                  String            @id @default(cuid())
  processDefinitionId String            @unique
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  knowledgeSnapshot   Json              @default("{}")
  confidenceScores    Json              @default("{}")
  completenessScore   Int               @default(0)
  shareToken          String?           @unique @default(cuid())
  shareExpiresAt      DateTime?
  riskShareToken      String?           @unique @default(cuid())
  riskShareExpiresAt  DateTime?
  version             Int               @default(0)
  lastAuditAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  items               IntelligenceItem[]
  auditLogs           IntelligenceAuditLog[]

  @@map("process_intelligence")
}

model IntelligenceItem {
  id               String                   @id @default(cuid())
  intelligenceId   String
  intelligence     ProcessIntelligence      @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)
  category         IntelligenceItemCategory
  question         String                   @db.Text
  context          String?                  @db.Text
  priority         Int                      @default(50)
  dependsOn        String[]
  status           IntelligenceItemStatus   @default(OPEN)
  resolution       String?                  @db.Text
  resolvedAt       DateTime?
  resolvedBy       String?
  sourceType       String
  sourceId         String?
  elementRef       String?                  // Stable element reference: "name|type|lane"
  insightType      String?                  // 'bottleneck' | 'improvement' | 'missing_path' | 'risk'
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([intelligenceId])
  @@index([status])
  @@index([category])
  @@map("intelligence_item")
}

model IntelligenceAuditLog {
  id                String              @id @default(cuid())
  intelligenceId    String
  intelligence      ProcessIntelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)
  triggerType       String
  triggerId         String?
  delta             Json
  completenessScore Int
  inputTokens       Int?
  outputTokens      Int?
  createdAt         DateTime            @default(now())

  @@index([intelligenceId])
  @@map("intelligence_audit_log")
}

// ============================================
// RISK MODELS
// ============================================

model ProcessRisk {
  id                  String            @id @default(cuid())
  processDefinitionId String
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)

  // ISO 31000 core fields
  title               String
  description         String            @db.Text
  riskType            RiskType
  status              RiskStatus        @default(IDENTIFIED)
  source              RiskSource

  // 5×5 matrix scores (1-5)
  severity            Int               @default(3)
  probability         Int               @default(3)
  riskScore           Int               @default(9)

  // Residual risk (after controls)
  residualSeverity    Int?
  residualProbability Int?
  residualScore       Int?

  // Context — BPMN node linkage
  affectedStep        String?           // Legacy: string label (kept for backward compat)
  affectedNodeId      String?           // FK to DiagramNode (preferred)
  affectedNode        DiagramNode?      @relation(fields: [affectedNodeId], references: [id], onDelete: SetNull)
  affectedRole        String?
  relatedItemId       String?
  // Procedure linkage
  linkedProcedureId   String?
  linkedProcedure     Procedure?        @relation(fields: [linkedProcedureId], references: [id], onDelete: SetNull)

  // Opportunity (positive risk)
  isOpportunity       Boolean           @default(false)
  opportunityValue    String?           @db.Text

  // FMEA fields
  failureMode         String?           @db.Text
  failureEffect       String?           @db.Text
  detectionDifficulty Int?
  rpn                 Int?

  // Visibility
  shareVisible        Boolean           @default(true)

  mitigations         RiskMitigation[]
  controls            RiskControl[]
  auditLogs           RiskAuditLog[]

  createdBy           String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([processDefinitionId])
  @@index([affectedNodeId])
  @@index([linkedProcedureId])
  @@index([status])
  @@index([riskScore])
  @@map("process_risk")
}

model RiskMitigation {
  id          String           @id @default(cuid())
  riskId      String
  risk        ProcessRisk      @relation(fields: [riskId], references: [id], onDelete: Cascade)
  action      String           @db.Text
  owner       String?
  deadline    DateTime?
  status      MitigationStatus @default(PLANNED)
  notes       String?          @db.Text
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([riskId])
  @@index([status])
  @@map("risk_mitigation")
}

model RiskControl {
  id            String               @id @default(cuid())
  riskId        String
  risk          ProcessRisk          @relation(fields: [riskId], references: [id], onDelete: Cascade)
  name          String
  description   String?              @db.Text
  controlType   ControlType
  effectiveness ControlEffectiveness @default(UNKNOWN)
  automated     Boolean              @default(false)
  system        String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([riskId])
  @@map("risk_control")
}

model RiskAuditLog {
  id        String      @id @default(cuid())
  riskId    String
  risk      ProcessRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  action    String
  delta     Json
  userId    String?
  createdAt DateTime    @default(now())

  @@index([riskId])
  @@map("risk_audit_log")
}

model ProcessTemplate {
  id          String   @id @default(cuid())
  framework   String
  industry    String
  name        String
  description String?  @db.Text
  structure   Json
  createdAt   DateTime @default(now())

  @@map("process_template")
}

// ============================================
// VERSIONING MODELS
// ============================================

model ProcessVersion {
  id                  String            @id @default(cuid())
  processDefinitionId String
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  version             Int
  name                String
  description         String?           @db.Text
  bpmnXml             String?           @db.Text
  goals               String[]
  triggers            String[]
  outputs             String[]
  changeNote          String?
  createdBy           String
  createdAt           DateTime          @default(now())

  @@unique([processDefinitionId, version])
  @@index([processDefinitionId])
  @@map("process_version")
}

model ArchitectureVersion {
  id             String              @id @default(cuid())
  architectureId String
  architecture   ProcessArchitecture @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  version        Int
  snapshot       Json
  changeNote     String?
  createdBy      String
  createdAt      DateTime            @default(now())

  @@unique([architectureId, version])
  @@index([architectureId])
  @@map("architecture_version")
}

// ============================================
// DOCUMENT MODELS
// ============================================

model Document {
  id                  String             @id @default(cuid())
  name                String
  description         String?
  mimeType            String
  filePath            String
  fileSize            Int
  organizationId      String
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processDefinitionId String?
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id], onDelete: SetNull)
  extractedText       String?            @db.Text
  isProcessed         Boolean            @default(false)
  versions            DocumentVersion[]
  createdBy           String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([organizationId])
  @@index([processDefinitionId])
  @@map("document")
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int
  filePath   String
  fileSize   Int
  changeNote String?
  createdBy  String
  createdAt  DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_version")
}

// ============================================
// MARKETING TOOLS (lead magnets)
// ============================================

model ToolLead {
  id         String    @id @default(cuid())
  email      String
  toolUsed   String // "bpmn-generator" | "sipoc-generator" | "raci-generator" | "process-audit" | "meeting-to-process" | "process-complexity" | "bpmn-to-text" | "roi-calculator"
  outputData Json? // stored result for email link
  ipAddress  String?
  source     String    @default("tool") // "tool" | "contact"
  nurture1At DateTime? // when nurture email 2 was sent
  nurture2At DateTime? // when nurture email 3 was sent
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([toolUsed])
  @@index([createdAt])
  @@map("tool_lead")
}

// ============================================
// COMPANY BRAIN — Organizational Knowledge Model
// ============================================

model CompanyBrain {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  orgContext          OrgContext?
  valueChainActivities ValueChainActivity[]
  processLinks        ProcessLink[]
  globalRoles         GlobalRole[]
  globalSystems       GlobalSystem[]
  enrichmentHistory   EnrichmentHistory[]

  lastEnrichedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("company_brain")
}

model OrgContext {
  id             String       @id @default(cuid())
  companyBrainId String       @unique
  companyBrain   CompanyBrain @relation(fields: [companyBrainId], references: [id], onDelete: Cascade)

  // Each field stores: text content
  mission        String?      @db.Text
  missionConfidence Float?
  missionSources Json?        // [{ sessionId, timestamp, quote }]

  vision         String?      @db.Text
  visionConfidence Float?
  visionSources  Json?

  values         Json?        // [{ name: string, description: string }]
  valuesConfidence Float?
  valuesSources  Json?

  industrySector    String?
  industrySubsector String?
  companySize       String?   // "small" | "medium" | "large" | "enterprise"
  geography         String?

  orgStructure   Json?        // { departments: [{ name, head, parentDept }] }
  businessModel  String?      @db.Text

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("org_context")
}

enum ValueChainType {
  PRIMARY
  SUPPORT
}

model ValueChainActivity {
  id             String         @id @default(cuid())
  companyBrainId String
  companyBrain   CompanyBrain   @relation(fields: [companyBrainId], references: [id], onDelete: Cascade)

  name           String
  type           ValueChainType
  description    String?        @db.Text
  orderIndex     Int            @default(0)
  linkedProcessIds String[]     // ProcessDefinition IDs mapped to this activity

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([companyBrainId])
  @@map("value_chain_activity")
}

enum ProcessLinkType {
  FEEDS           // Output of A is input to B
  TRIGGERS        // Completion of A starts B
  DEPENDS         // A requires B to be done first
  HANDOFF         // A passes work to B (cross-department)
}

model ProcessLink {
  id             String          @id @default(cuid())
  companyBrainId String
  companyBrain   CompanyBrain    @relation(fields: [companyBrainId], references: [id], onDelete: Cascade)

  fromProcessId  String          // ProcessDefinition ID
  toProcessId    String          // ProcessDefinition ID
  linkType       ProcessLinkType
  description    String?

  confidence     Float           @default(0.5)
  source         String          @default("ai") // "ai" | "manual"

  createdAt      DateTime        @default(now())

  @@unique([companyBrainId, fromProcessId, toProcessId, linkType])
  @@index([companyBrainId])
  @@map("process_link")
}

model GlobalRole {
  id             String       @id @default(cuid())
  companyBrainId String
  companyBrain   CompanyBrain @relation(fields: [companyBrainId], references: [id], onDelete: Cascade)

  name           String
  department     String?
  title          String?
  appearsInProcessIds String[] // ProcessDefinition IDs where this role appears

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([companyBrainId, name])
  @@index([companyBrainId])
  @@map("global_role")
}

model GlobalSystem {
  id             String       @id @default(cuid())
  companyBrainId String
  companyBrain   CompanyBrain @relation(fields: [companyBrainId], references: [id], onDelete: Cascade)

  name           String
  vendor         String?
  description    String?
  usedInProcessIds String[]   // ProcessDefinition IDs where this system is used

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([companyBrainId, name])
  @@index([companyBrainId])
  @@map("global_system")
}

enum EnrichmentSourceType {
  SESSION
  DOCUMENT
  MANUAL
}

model EnrichmentHistory {
  id             String              @id @default(cuid())
  companyBrainId String
  companyBrain   CompanyBrain        @relation(fields: [companyBrainId], references: [id], onDelete: Cascade)

  sourceType     EnrichmentSourceType
  sourceId       String              // MeetingSession ID or Document ID
  field          String              // e.g., "orgContext.mission", "valueChainActivity.Logistics"
  oldValue       String?             @db.Text
  newValue       String?             @db.Text
  confidence     Float?
  action         String              @default("update") // "create" | "update" | "delete"

  createdAt      DateTime            @default(now())

  @@index([companyBrainId])
  @@index([sourceId])
  @@map("enrichment_history")
}

// Org-level deliverables (not session-scoped)
model OrgDeliverable {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type           String       // "mission_vision" | "value_chain" | "landscape" | "horizontal_view" | "procedure" | "gap_analysis" | "benchmark" | "progress" | "executive_report"
  status         String       @default("pending") // "pending" | "running" | "completed" | "failed" | "draft"
  data           Json?        // Output of the pipeline (schema varies by type)
  error          String?
  confidence     Float?       // Overall confidence score

  // For procedure type: which process/activity this is for
  processDefinitionId String?

  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, type])
  @@map("org_deliverable")
}

// ============================================
// CLIENT INTAKE MODELS
// ============================================

model ClientIntakeResponse {
  id           String          @id @default(cuid())
  sessionId    String
  session      MeetingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionKey  String          // intelligenceItem:{id} | default:{1|2|3} | custom:{uuid}
  questionText String          @db.Text
  response     String?         @db.Text
  respondedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([sessionId])
  @@map("client_intake_response")
}

// ============================================
// BASE MODELS
// ============================================

enum PurchaseType {
  SUBSCRIPTION
  ONE_TIME
}

model Purchase {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String?
  type           PurchaseType
  customerId     String
  subscriptionId String?       @unique
  priceId        String
  status         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([subscriptionId])
  @@map("purchase")
}

// ============================================
// AI USAGE TRACKING
// ============================================

model AiUsageLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline       String       // "process-extraction" | "teleprompter" | etc.
  model          String       // actual model used e.g. "claude-sonnet-4-6"
  inputTokens    Int
  outputTokens   Int
  durationMs     Int?
  success        Boolean      @default(true)
  error          String?      @db.Text
  metadata       Json?        // sessionId, processId for tracing
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([pipeline])
  @@map("ai_usage_log")
}

model ExternalCostLog {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service          String       // "deepgram-stt" | "recall-bot"
  unitType         String       // "audio_minutes" | "bot_minutes"
  units            Float
  estimatedCostUsd Float
  metadata         Json?        // sessionId for tracing
  createdAt        DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@map("external_cost_log")
}

// ============================================
// ANONYMOUS ONBOARDING (RADIOGRAFIA)
// ============================================

model AnonymousSession {
  id                  String    @id @default(cuid())
  fingerprint         String    // IP hash + user-agent hash for rate limiting
  phase               String    @default("input") // input|crawl|instant|deepen|sipoc|reveal|risks|convert
  sourceUrl           String?   // Company website URL (primary input)
  businessContext     String?   @db.Text // Crawled website text (up to 3000 words)
  businessDescription String?   @db.Text // Manual fallback paragraph
  industry            String?
  processName         String?
  sipocData           Json?     // SipocResult from extraction
  knowledgeData       Json?     // KnowledgeSnapshot
  diagramNodes        Json?     // DiagramNode[]
  riskResults         Json?     // RiskAuditResult (instant mode)
  deepRiskResults     Json?     // RiskAuditResult (full mode with FMEA)
  researchData        Json?     // Business intelligence research findings from web search
  conversationLog     Json?     // Array<{ role, content, timestamp }>
  completenessScore   Int       @default(0)
  shareToken          String?   @unique // Public share token for scan results
  shareExpiresAt      DateTime? // Share link expiry (7 days from generation)
  convertedToUserId   String?
  convertedAt         DateTime?
  expiresAt           DateTime  // 24h from creation
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([fingerprint])
  @@index([expiresAt])
  @@map("anonymous_session")
}

// ============================================
// SIMULATION & EVALUATION MODELS
// ============================================

enum SimulationTemplateStatus {
  GENERATING
  GENERATION_FAILED
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SimulationTargetRole {
  DIRECTOR_OPERACIONES
  DIRECTOR_COMPRAS
  DIRECTOR_CALIDAD
  DIRECTOR_FINANZAS
  DIRECTOR_LOGISTICA
  GERENTE_PLANTA
  CONTROLLER
  CEO
  CUSTOM
}

enum DecisionRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SimulationRunStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model SimulationTemplate {
  id                    String                   @id @default(cuid())
  organizationId        String
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processDefinitionId   String
  processDefinition     ProcessDefinition        @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  processVersionId      String?                  // Pinned to specific process version
  title                 String
  narrative             String                   @db.Text // Pre-generated scenario narrative
  targetRole            SimulationTargetRole     @default(CUSTOM)
  customRoleName        String?                  // When targetRole is CUSTOM
  status                SimulationTemplateStatus @default(GENERATING)
  version               Int                      @default(1)
  riskIds               String[]                 // IDs of ProcessRisk entries this template evaluates
  generationPrompt      String?                  @db.Text // Prompt used to generate (for debugging/regeneration)
  scenarios             SimulationScenario[]
  createdBy             String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([organizationId])
  @@index([processDefinitionId])
  @@index([status])
  @@map("simulation_template")
}

model SimulationScenario {
  id         String             @id @default(cuid())
  templateId String
  template   SimulationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  context    Json               // Parameterized variables: company name, amounts, names, etc.
  decisions  Decision[]
  runs       SimulationRun[]
  createdAt  DateTime           @default(now())

  @@index([templateId])
  @@map("simulation_scenario")
}

model Decision {
  id                  String             @id @default(cuid())
  scenarioId          String
  scenario            SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  order               Int                // Sequential: 1, 2, 3...
  prompt              String             @db.Text // The situation the user faces
  options             Json               // Array<{ label: string, description: string }>
  consequences        Json               // Array<string> — flavor text per option chosen, indexed by option
  proceduralReference String?            @db.Text // What the procedure says for this decision (max ~200 tokens)
  riskLevelByOption   Json               // Array<DecisionRiskLevel> — risk level per option (input for scoring, NOT correctness)
  responses           DecisionResponse[]

  @@unique([scenarioId, order])
  @@index([scenarioId])
  @@map("simulation_decision")
}

model DecisionResponse {
  id           String        @id @default(cuid())
  runId        String
  run          SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  decisionId   String
  decision     Decision      @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  chosenOption Int           // Index of chosen option (0-based)
  timeToDecide Int?          // Seconds spent on this decision
  createdAt    DateTime      @default(now())

  @@unique([runId, decisionId])
  @@index([runId])
  @@index([decisionId])
  @@map("decision_response")
}

model SimulationRun {
  id           String              @id @default(cuid())
  scenarioId   String
  scenario     SimulationScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       SimulationRunStatus @default(IN_PROGRESS)
  responses    DecisionResponse[]
  // Scoring (populated after completion by AI evaluation)
  alignment    Int?                // 0-100: alignment with procedure
  riskLevel    Int?                // 0-100: risk introduced by decisions
  criterio     Int?                // 0-100: quality of judgment (AI-evaluated)
  overallScore Int?                // Weighted: 0.3*alignment + 0.3*(100-riskLevel) + 0.4*criterio
  errorPatterns Json?              // Array<string> — detected error patterns
  aiFeedback   String?             @db.Text // AI-generated feedback text
  duration     Int?                // Total seconds
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([scenarioId])
  @@index([userId])
  @@index([status])
  @@map("simulation_run")
}

model HumanRiskProfile {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  overallScore       Int?     // Weighted aggregate across all simulations
  totalSimulations   Int      @default(0)
  patternsByProcess  Json?    // Array<{ processId, processName, avgAlignment, avgRiskLevel, dominantErrorPattern, simulationCount }>
  strengthAreas      Json?    // Array<string>
  riskAreas          Json?    // Array<string>
  recommendedTraining Json?   // Array<string> — AI-generated labels, NOT curated content
  lastUpdatedAt      DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("human_risk_profile")
}

// ============================================
// PROCEDURE MODEL (first-class entity)
// ============================================

enum ProcedureStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

model Procedure {
  id                    String          @id @default(cuid())
  processDefinitionId   String
  processDefinition     ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  organizationId        String
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nodeId                String?         // Optional: linked to a specific BPMN DiagramNode
  title                 String
  version               Int             @default(1)
  status                ProcedureStatus @default(DRAFT)
  // Structured content (from existing SOP generator)
  objective             String?         @db.Text
  scope                 String?         @db.Text
  responsible           String?
  frequency             String?         // daily, weekly, monthly, per_event
  prerequisites         Json?           // Array<string>
  steps                 Json?           // Array<{ action, description, responsibleRole, systems, inputs, outputs, controls, exceptions, estimatedDuration }>
  indicators            Json?           // Array<string> — KPIs
  // Rich text content (TipTap JSON for manual editing)
  richContent           Json?           // TipTap document JSON
  // Control points summary for simulation evaluation (max ~500 tokens)
  controlPointsSummary  String?         @db.Text
  // Linked risks
  linkedRiskIds         String[]        // Legacy: IDs array (kept for backward compat)
  linkedRisks           ProcessRisk[]   // Reverse relation from ProcessRisk.linkedProcedure
  // Audit
  createdBy             String
  approvedBy            String?
  approvedAt            DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  // Version history
  versions              ProcedureVersion[]
  changeConfirmations   ChangeConfirmation[]

  @@index([processDefinitionId])
  @@index([organizationId])
  @@index([nodeId])
  @@index([status])
  @@map("procedure")
}

// ============================================
// PROCEDURE VERSION (snapshots for history)
// ============================================

model ProcedureVersion {
  id           String          @id @default(cuid())
  procedureId  String
  procedure    Procedure       @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  version      Int
  status       ProcedureStatus
  content      Json            // Full snapshot: { title, objective, scope, steps, indicators, richContent }
  changeNote   String?         @db.Text
  changedBy    String
  changedAt    DateTime        @default(now())

  @@index([procedureId])
  @@map("procedure_version")
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  // Change management
  PROCESS_UPDATED
  PROCEDURE_UPDATED
  CHANGE_CONFIRMATION_REQUESTED
  CHANGE_CONFIRMED
  CHANGE_OVERDUE

  // Evaluations
  EVALUATION_ASSIGNED
  EVALUATION_COMPLETED
  EVALUATION_RESULTS_READY

  // Collaboration (F3-01)
  COMMENT_ADDED
  COMMENT_MENTION

  // Onboarding (F3-04)
  ONBOARDING_ASSIGNED
  ONBOARDING_COMPLETED

  // Certification (F3-05)
  CERTIFICATION_EARNED
  CERTIFICATION_EXPIRING

  // System
  MEMBER_INVITED
  WEEKLY_DIGEST
}

model Notification {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipientId     String
  recipient       User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId         String?
  actor           User?            @relation("NotificationActor", fields: [actorId], references: [id])

  type            NotificationType

  // Polymorphic reference to the source entity
  entityType      String           // "process" | "procedure" | "evaluation" | "comment" | "change_request"
  entityId        String

  // Display data (denormalized for fast rendering)
  title           String
  body            String           @db.Text
  url             String           // Deep link into the app

  // State
  read            Boolean          @default(false)
  readAt          DateTime?
  archived        Boolean          @default(false)

  // Email digest tracking
  emailSent       Boolean          @default(false)
  emailSentAt     DateTime?

  createdAt       DateTime         @default(now())

  @@index([recipientId, read, createdAt])
  @@index([organizationId, createdAt])
  @@index([recipientId, emailSent])
  @@map("notification")
}

// ============================================
// CHANGE MANAGEMENT
// ============================================

enum ChangeType {
  PROCESS_STRUCTURE
  PROCEDURE_CONTENT
  RISK_LEVEL_CHANGE
  RACI_CHANGE
}

enum ChangeConfirmationStatus {
  PENDING
  COMPLETED
  OVERDUE
  CANCELLED
}

model ChangeConfirmation {
  id              String                     @id @default(cuid())
  organizationId  String
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  processId       String?
  process         ProcessDefinition?         @relation(fields: [processId], references: [id])
  procedureId     String?
  procedure       Procedure?                 @relation(fields: [procedureId], references: [id])

  changedById     String
  changedBy       User                       @relation("ChangeInitiator", fields: [changedById], references: [id])

  changeSummary   String                     @db.Text
  changeType      ChangeType

  totalRequired   Int
  totalConfirmed  Int                        @default(0)
  deadline        DateTime?
  status          ChangeConfirmationStatus   @default(PENDING)

  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  confirmations   ChangeConfirmationResponse[]

  @@index([organizationId, status])
  @@index([processId])
  @@index([procedureId])
  @@map("change_confirmation")
}

model ChangeConfirmationResponse {
  id                    String             @id @default(cuid())
  changeConfirmationId  String
  changeConfirmation    ChangeConfirmation @relation(fields: [changeConfirmationId], references: [id], onDelete: Cascade)
  userId                String
  user                  User               @relation(fields: [userId], references: [id])

  confirmed             Boolean            @default(false)
  confirmedAt           DateTime?
  comment               String?            @db.Text

  createdAt             DateTime           @default(now())

  @@unique([changeConfirmationId, userId])
  @@index([userId, confirmed])
  @@map("change_confirmation_response")
}

// ============================================
// NOTIFICATION PREFERENCES
// ============================================

enum DigestFrequency {
  REALTIME
  DAILY
  WEEKLY
  NONE
}

model NotificationPreference {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  inApp           Boolean          @default(true)
  email           Boolean          @default(true)
  digestFrequency DigestFrequency  @default(DAILY)
  mutedTypes      String[]         @default([])

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, organizationId])
  @@map("notification_preference")
}

