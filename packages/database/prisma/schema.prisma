datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "./zod"
  config   = "./zod-generator.config.json"
}

model User {
  id                       String       @id @default(cuid())
  name                     String
  email                    String
  emailVerified            Boolean
  image                    String?
  createdAt                DateTime
  updatedAt                DateTime
  username                 String?
  role                     String?
  banned                   Boolean?
  banReason                String?
  banExpires               DateTime?
  onboardingComplete       Boolean      @default(false)
  paymentsCustomerId       String?
  locale                   String?
  displayUsername          String?
  twoFactorEnabled         Boolean?
  lastActiveOrganizationId String?
  sessions                 Session[]
  accounts                 Account[]
  passkeys                 Passkey[]
  invitations              Invitation[]
  purchases                Purchase[]
  members                  Member[]
  twofactors               TwoFactor[]
  meetingSessions          MeetingSession[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  activeOrganizationId String?

  token     String
  createdAt DateTime
  updatedAt DateTime

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  idToken      String?   @db.Text
  expiresAt    DateTime?
  password     String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime

  createdAt DateTime?
  updatedAt DateTime?

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Organization {
  id                 String       @id @default(cuid())
  name               String
  slug               String?
  logo               String?
  createdAt          DateTime
  metadata           String?
  paymentsCustomerId String?
  members            Member[]
  invitations        Invitation[]
  purchases          Purchase[]
  clients            Client[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ============================================
// PROZEA MODELS
// ============================================

enum SessionType {
  DISCOVERY
  DEEP_DIVE
  CONTINUATION
}

enum ProcessLevel {
  PROCESS
  SUBPROCESS
  TASK
  PROCEDURE
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum SessionStatus {
  SCHEDULED
  CONNECTING
  ACTIVE
  ENDED
  FAILED
}

enum NodeState {
  FORMING
  CONFIRMED
  REJECTED
  ARCHIVED
}

enum NodeType {
  START_EVENT
  END_EVENT
  TASK
  EXCLUSIVE_GATEWAY
  PARALLEL_GATEWAY
}

model Client {
  id                String       @id @default(cuid())
  name              String
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  industry          String?
  operationsProfile String?      @db.Text
  businessModel     String?      @db.Text
  employeeCount     String?
  notes             String?      @db.Text
  projects          Project[]
  documents         Document[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId])
  @@map("client")
}

model Project {
  id           String               @id @default(cuid())
  name         String
  description  String?              @db.Text
  goals        String[]
  status       ProjectStatus        @default(ACTIVE)
  clientId     String
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessions     MeetingSession[]
  architecture ProcessArchitecture?
  documents    Document[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([clientId])
  @@map("project")
}

model ProcessArchitecture {
  id          String                @id @default(cuid())
  projectId   String                @unique
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  definitions ProcessDefinition[]
  versions    ArchitectureVersion[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@map("process_architecture")
}

model ProcessDefinition {
  id             String              @id @default(cuid())
  architectureId String
  architecture   ProcessArchitecture @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  name           String
  description    String?             @db.Text
  level          ProcessLevel        @default(PROCESS)
  parentId       String?
  parent         ProcessDefinition?  @relation("ProcessHierarchy", fields: [parentId], references: [id])
  children       ProcessDefinition[] @relation("ProcessHierarchy")
  owner          String?
  goals          String[]
  triggers       String[]
  outputs        String[]
  processStatus  String              @default("DRAFT")
  bpmnXml        String?             @db.Text
  priority       Int                 @default(0)
  sessions       MeetingSession[]
  versions       ProcessVersion[]
  createdAt      DateTime            @default(now())

  @@index([architectureId])
  @@index([parentId])
  @@map("process_definition")
}

model MeetingSession {
  id                  String            @id @default(cuid())
  type                SessionType
  status              SessionStatus     @default(SCHEDULED)
  meetingUrl          String
  projectId           String
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processDefinitionId String?
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id])
  userId              String
  user                User              @relation(fields: [userId], references: [id])

  // Session continuation
  continuationOf      String?
  previousSession     MeetingSession?   @relation("SessionContinuation", fields: [continuationOf], references: [id])
  nextSessions        MeetingSession[]  @relation("SessionContinuation")

  // Call bot
  recallBotId         String?
  recallBotStatus     String?

  // Timing
  startedAt           DateTime?
  endedAt             DateTime?

  // BPMN data
  bpmnXml             String?           @db.Text
  diagramNodes        DiagramNode[]
  transcriptEntries   TranscriptEntry[]
  correctionLogs      CorrectionLog[]
  teleprompterLogs    TeleprompterLog[]
  sessionSummary      SessionSummary?

  // Share
  shareToken          String?           @unique @default(cuid())

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([shareToken])
  @@map("meeting_session")
}

model DiagramNode {
  id        String         @id @default(cuid())
  sessionId String
  session   MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nodeType  NodeType
  label     String
  state     NodeState      @default(FORMING)
  lane      String?
  positionX Float          @default(0)
  positionY Float          @default(0)

  // Connections stored as JSON array of target node IDs
  connections String[]

  // Timing
  formedAt    DateTime     @default(now())
  confirmedAt DateTime?
  rejectedAt  DateTime?

  // Parent reference for cascade rejection
  parentId    String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sessionId])
  @@index([state])
  @@map("diagram_node")
}

model TranscriptEntry {
  id        String         @id @default(cuid())
  sessionId String
  session   MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker   String
  text      String         @db.Text
  timestamp Float
  confidence Float?

  createdAt DateTime       @default(now())

  @@index([sessionId])
  @@index([timestamp])
  @@map("transcript_entry")
}

model CorrectionLog {
  id        String         @id @default(cuid())
  sessionId String
  session   MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nodeId    String
  action    String         // "confirm", "reject", "edit", "undo"
  oldState  String?
  newState  String?
  oldLabel  String?
  newLabel  String?
  createdAt DateTime       @default(now())

  @@index([sessionId])
  @@map("correction_log")
}

model TeleprompterLog {
  id        String         @id @default(cuid())
  sessionId String
  session   MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question  String         @db.Text
  used      Boolean        @default(false)
  skipped   Boolean        @default(false)
  shownAt   DateTime       @default(now())

  @@index([sessionId])
  @@map("teleprompter_log")
}

model SessionSummary {
  id          String         @id @default(cuid())
  sessionId   String         @unique
  session     MeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  summary     String         @db.Text
  actionItems String[]
  emailSentAt DateTime?

  createdAt   DateTime       @default(now())

  @@map("session_summary")
}

// ============================================
// VERSIONING MODELS
// ============================================

model ProcessVersion {
  id                  String            @id @default(cuid())
  processDefinitionId String
  processDefinition   ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  version             Int
  name                String
  description         String?           @db.Text
  bpmnXml             String?           @db.Text
  goals               String[]
  triggers            String[]
  outputs             String[]
  changeNote          String?
  createdBy           String
  createdAt           DateTime          @default(now())

  @@unique([processDefinitionId, version])
  @@index([processDefinitionId])
  @@map("process_version")
}

model ArchitectureVersion {
  id             String              @id @default(cuid())
  architectureId String
  architecture   ProcessArchitecture @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  version        Int
  snapshot       Json
  changeNote     String?
  createdBy      String
  createdAt      DateTime            @default(now())

  @@unique([architectureId, version])
  @@index([architectureId])
  @@map("architecture_version")
}

// ============================================
// DOCUMENT MODELS
// ============================================

model Document {
  id            String            @id @default(cuid())
  name          String
  description   String?
  mimeType      String
  filePath      String
  fileSize      Int
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  extractedText String?           @db.Text
  isProcessed   Boolean           @default(false)
  versions      DocumentVersion[]
  createdBy     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@map("document")
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    Int
  filePath   String
  fileSize   Int
  changeNote String?
  createdBy  String
  createdAt  DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_version")
}

// ============================================
// SUPASTARTER MODELS (existing)
// ============================================

enum PurchaseType {
  SUBSCRIPTION
  ONE_TIME
}

model Purchase {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String?
  type           PurchaseType
  customerId     String
  subscriptionId String?       @unique
  priceId        String
  status         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([subscriptionId])
  @@map("purchase")
}

