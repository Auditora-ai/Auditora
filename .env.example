# =============================================================================
# Auditora.ai - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For staging, copy to .env.staging and adjust accordingly.
# =============================================================================

# ------------------------------------------------------------------
# CORE
# ------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------------
# DATABASE (PostgreSQL)
# ------------------------------------------------------------------
# Main connection (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auditora?schema=public"
# Direct connection (used by Prisma CLI for migrations)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/auditora?schema=public"

# ------------------------------------------------------------------
# AUTH (Better Auth)
# ------------------------------------------------------------------
BETTER_AUTH_SECRET="change-me-to-a-64-char-random-string"
# Public URL of the SaaS app (used for callback URLs, CORS, etc.)
NEXT_PUBLIC_SAAS_URL="http://localhost:3000"

# ------------------------------------------------------------------
# AI PROVIDERS (at least one required)
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
GLM_MODEL=glm-5.1

# ------------------------------------------------------------------
# SPEECH-TO-TEXT (at least one for meeting transcription)
# ------------------------------------------------------------------
DEEPGRAM_API_KEY=

# ------------------------------------------------------------------
# MEETING BOT (at least one for joining calls)
# ------------------------------------------------------------------
RECALL_API_KEY=
RECALL_REGION=us
RECALL_WEBHOOK_SECRET=

# ------------------------------------------------------------------
# EMAIL (at least one provider)
# ------------------------------------------------------------------
# Resend (recommended)
RESEND_API_KEY=
MAIL_FROM="Auditora <noreply@auditora.ai>"

# SMTP fallback
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# Mailgun (alternative)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Plunk (alternative)
PLUNK_API_KEY=

# ------------------------------------------------------------------
# STORAGE (S3-compatible)
# ------------------------------------------------------------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
NEXT_PUBLIC_AVATARS_BUCKET_NAME="avatars"
NEXT_PUBLIC_DOCUMENTS_BUCKET_NAME="documents"

# ------------------------------------------------------------------
# OAUTH PROVIDERS (optional, for social login)
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ------------------------------------------------------------------
# PAYMENTS - STRIPE (primary provider)
# ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PRICE_ID_STARTER_MONTHLY=
PRICE_ID_STARTER_YEARLY=
PRICE_ID_GROWTH_MONTHLY=
PRICE_ID_GROWTH_YEARLY=
PRICE_ID_SCALE_MONTHLY=
PRICE_ID_SCALE_YEARLY=

# ------------------------------------------------------------------
# PAYMENTS - ALTERNATIVE PROVIDERS (optional)
# ------------------------------------------------------------------
# LemonSqueezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Polar
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# Creem
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=

# Dodo Payments
DODO_PAYMENTS_API_KEY=

# ------------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------------
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
ORG_KEY_ENCRYPTION_SECRET="change-me-to-a-random-32-char-string"
CRON_SECRET="change-me-to-a-random-string"

# ------------------------------------------------------------------
# ANALYTICS (optional)
# ------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_PLAUSIBLE_URL=
NEXT_PUBLIC_PIRSCH_CODE=
NEXT_PUBLIC_UMAMI_TRACKING_ID=

# ------------------------------------------------------------------
# SEARCH / CRAWLING (optional)
# ------------------------------------------------------------------
FIRECRAWL_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=

# ------------------------------------------------------------------
# REDIS (optional, for rate limiting)
# ------------------------------------------------------------------
REDIS_URL=

# ------------------------------------------------------------------
# FEATURE FLAGS (optional, for disabling public features in staging)
# ------------------------------------------------------------------
DISABLE_PUBLIC_EXTRACTION=false
DISABLE_PUBLIC_SCAN=false
DISABLE_PUBLIC_TOOLS=false

# ------------------------------------------------------------------
# PUBLIC URLS (important for staging - override these)
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MARKETING_URL="http://localhost:3001"
NEXT_PUBLIC_DOCS_URL="http://localhost:3002"
NEXT_PUBLIC_TUNNEL_URL=

# Debug key for dev/staging
DEBUG_KEY=
