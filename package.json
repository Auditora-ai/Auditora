{
	"name": "auditora",
	"private": true,
	"scripts": {
		"build": "dotenv -c -- turbo build",
		"dev": "dotenv -c -- turbo dev --concurrency 15",
		"type-check": "dotenv -c -- turbo type-check",
		"start": "dotenv -c -- turbo start",
		"lint": "biome lint",
		"check": "biome check --write",
		"clean": "turbo clean",
		"format": "biome format --write"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.28.2",
	"devDependencies": {
		"@ai-sdk/anthropic": "catalog:",
		"@biomejs/biome": "catalog:",
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"ai": "catalog:",
		"dotenv-cli": "catalog:",
		"shadcn": "^4.1.2",
		"tsx": "catalog:",
		"turbo": "^2.9.4",
		"typescript": "catalog:",
		"vitest": "^4.1.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"@swc/core",
			"prisma",
			"prisma-zod-generator",
			"sharp"
		]
	},
	"dependencies": {
		"tw-animate-css": "^1.4.0"
	}
}
